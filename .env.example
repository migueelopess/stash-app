# Supabase (obter em https://supabase.com/dashboard → projeto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # só server, para o cron — NUNCA expor no cliente

# Enable Banking (obter em https://enablebanking.com → aplicação)
EB_APPLICATION_ID=
EB_PRIVATE_KEY=                   # PEM, só server
EB_REDIRECT_URL=http://localhost:3000/api/callback

# Proteção do endpoint de sync
CRON_SECRET=
